#!/bin/sh

# PureCore UAC2 Gadget Auto-start Script
#
# EMULATED via configfs:
# ✓ Device Qualifier: 0x00/0x00/0x00
# ✓ Self-powered, 100mA
# ✓ Minimal string descriptors
# ✓ iConfiguration = 0x00, iFunction = 0x00

GADGET=/sys/kernel/config/usb_gadget/purecore
FUNC=$GADGET/functions/uac2.usb0

start() {
    echo "Starting PureCore UAC2 gadget..."
    sleep 2  # Give time for USB initialization

    # Check if UDC is available
    if [ ! -d /sys/class/udc ]; then
        echo "UDC not available, skipping PureCore gadget"
        return 1
    fi

    # Completely remove old gadget if it exists
    if [ -d "$GADGET" ]; then
        echo "" > $GADGET/UDC 2>/dev/null
        rm -f $GADGET/configs/c.1/uac2.usb0 2>/dev/null
        rmdir $GADGET/configs/c.1 2>/dev/null
        rmdir $FUNC 2>/dev/null
        rmdir $GADGET/strings/0x409 2>/dev/null
        rmdir $GADGET 2>/dev/null
    fi

    mkdir -p $GADGET

    # Device Descriptor
    echo 0x152A > $GADGET/idVendor
    echo 0x8852 > $GADGET/idProduct
    echo 0x0312 > $GADGET/bcdDevice
    echo 0x0200 > $GADGET/bcdUSB
    echo 0x00 > $GADGET/bDeviceClass
    echo 0x00 > $GADGET/bDeviceSubClass
    echo 0x00 > $GADGET/bDeviceProtocol
    echo 64 > $GADGET/bMaxPacketSize0

    # Device Strings
    mkdir -p $GADGET/strings/0x409
    echo "PureCore" > $GADGET/strings/0x409/manufacturer
    echo "PureCore USB Hi-Resolution Audio" > $GADGET/strings/0x409/product
    echo "" > $GADGET/strings/0x409/serialnumber

    # UAC2 Function
    mkdir -p $FUNC

    # CRITICAL FIX: Stock f_uac2.c has REVERSED naming!
    # p_chmask controls EPIN (capture/mic), c_chmask controls EPOUT (playback/speaker)
    echo 0 > $FUNC/p_chmask
    echo 3 > $FUNC/c_chmask
    # PCM rates up to 768kHz + DSD LRCK rates
    echo "44100,48000,88200,96000,176400,192000,352800,384000,705600,768000" > $FUNC/c_srate
    echo 4 > $FUNC/c_ssize
    echo 1 > $FUNC/c_mute_present
    echo 1 > $FUNC/c_volume_present

    # Fix p_volume parameters (kernel validates regardless of p_chmask)
    echo 0 > $FUNC/p_volume_min
    echo 256 > $FUNC/p_volume_max
    echo 256 > $FUNC/p_volume_res

    # Set p_srate and p_ssize (required for proper UAC2 function)
    echo "44100,48000,88200,96000,176400,192000,352800,384000,705600,768000" > $FUNC/p_srate
    echo 4 > $FUNC/p_ssize

    # Parameters for DSD512 support
    echo 8 > $FUNC/req_number
    # fb_max=24: 2.4% overhead for async feedback
    echo 24 > $FUNC/fb_max

    # bInterval for high-speed isochronous endpoints.
    # bInterval=1 → every microframe (125µs) → 8000 packets/sec.
    # At DSD512 (705600 Hz, 2ch, 4B): 706 bytes/pkt — fits in 1024.
    # Default (0=auto) → bInterval=4 (1ms) → DSD512 starves!
    echo 1 > $FUNC/c_hs_bint
    echo 1 > $FUNC/p_hs_bint

    # Function name
    echo "PureCore" > $FUNC/function_name

    # Configuration 1 - UAC2 Audio (Self-powered)
    mkdir -p $GADGET/configs/c.1
    echo 0xC0 > $GADGET/configs/c.1/bmAttributes
    echo 100 > $GADGET/configs/c.1/MaxPower
    ln -s $FUNC $GADGET/configs/c.1/

    # Enable gadget
    ls /sys/class/udc > $GADGET/UDC

    echo "PureCore UAC2 gadget started"
}

case "$1" in
  start)
    start
    ;;
  stop)
    echo "Stopping PureCore gadget..."
    [ -f "$GADGET/UDC" ] && echo "" > $GADGET/UDC 2>/dev/null
    ;;
  restart)
    $0 stop
    sleep 1
    $0 start
    ;;
  *)
    echo "Usage: $0 {start|stop|restart}"
    exit 1
esac
